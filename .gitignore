backend/data.db-wal
backend/*.db

# 環境變數（機密！不上傳）
.env
backend/.env

# 上傳的圖片（需另外備份）
backend/uploads/*
!backend/uploads/.gitkeep

# 系統檔案
.DS_Store
Thumbs.db
